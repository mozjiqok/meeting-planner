APP_NAME="Meeting Planner Bot"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU
APP_TIMEZONE=Asia/Vladivostok

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# For production with PostgreSQL, uncomment and fill in:
# DB_CONNECTION=pgsql
# DB_HOST=db
# DB_PORT=5432
# DB_DATABASE=meeting_planner
# DB_USERNAME=laravel
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_TOKEN=

# Your personal Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=

# Your channel username including @, e.g. @mychannel
TELEGRAM_CHANNEL_USERNAME=

# ─── Admin Web Panel ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=changeme

DOCKER_HTTP_PORT=80
DOCKER_HTTPS_PORT=443